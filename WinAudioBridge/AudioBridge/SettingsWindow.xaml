<Window x:Class="WpfApp1.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinAudioBridge 设置"
        Icon="Assets/app.ico"
        Height="680"
        Width="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Loaded="SettingsWindow_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock VerticalAlignment="Center" Text="编码" />
            <ComboBox x:Name="EncodingComboBox" Grid.Column="2" MinWidth="180" />

            <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="采样率" />
            <ComboBox x:Name="SampleRateComboBox" Grid.Row="2" Grid.Column="2" MinWidth="180" />

            <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="声道数" />
            <ComboBox x:Name="ChannelsComboBox" Grid.Row="4" Grid.Column="2" MinWidth="180" />

            <TextBlock Grid.Row="6" VerticalAlignment="Center" Text="Buffer 大小" />
            <ComboBox x:Name="BufferComboBox" Grid.Row="6" Grid.Column="2" MinWidth="180" />

            <TextBlock Grid.Row="8" VerticalAlignment="Center" Text="Android 应用包名" />
            <TextBox x:Name="AndroidPackageNameTextBox" Grid.Row="8" Grid.Column="2" MinWidth="180" />

            <TextBlock Grid.Row="10" VerticalAlignment="Center" Text="自动重连" />
            <CheckBox x:Name="EnableAutoReconnectCheckBox"
                      Grid.Row="10"
                      Grid.Column="2"
                      VerticalAlignment="Center"
                      Content="启动后自动连接、配置修改后自动重连，并在断开后持续尝试重连" />

            <TextBlock Grid.Row="12"
                       Grid.ColumnSpan="3"
                       Foreground="#666"
                       TextWrapping="Wrap"
                       Text="修改配置后将用于后续音频采集与通信模块。当前版本已支持通过 ADB 查询已连接设备，并识别指定包名的 Android 音频应用是否正在运行。" />
        </Grid>

        <Border Grid.Row="2"
                Padding="16"
                Background="#F8F8F8"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" Text="已连接 Android 设备" />
                    <Button x:Name="RefreshDevicesButton"
                            Width="100"
                            HorizontalAlignment="Right"
                            Click="RefreshDevices_Click">刷新设备</Button>
                </DockPanel>

                <TextBlock x:Name="DeviceStatusTextBlock"
                           Grid.Row="2"
                           Foreground="#666"
                           Text="正在准备设备查询..." />

                <TextBlock x:Name="SelectedDeviceTextBlock"
                           Grid.Row="4"
                           Foreground="#666"
                           Text="当前未指定优先设备，将自动选择可用设备。" />

                <ListView x:Name="DevicesListView" Grid.Row="6" Margin="0,4,0,0" SelectionChanged="DevicesListView_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="220" DisplayMemberBinding="{Binding Model}" Header="设备名称" />
                            <GridViewColumn Width="170" DisplayMemberBinding="{Binding Serial}" Header="序列号" />
                            <GridViewColumn Width="120" DisplayMemberBinding="{Binding State}" Header="连接状态" />
                            <GridViewColumn Width="120" DisplayMemberBinding="{Binding AppStatusText}" Header="音频应用状态" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="90" Margin="0,0,8,0" Click="ResetDefaults_Click">恢复默认值</Button>
            <Button Width="90" Margin="0,0,8,0" Click="Cancel_Click">取消</Button>
            <Button Width="90" Click="Save_Click">保存</Button>
        </StackPanel>
    </Grid>
</Window>
