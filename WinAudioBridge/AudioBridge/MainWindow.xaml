<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="WinAudioBridge"
        Icon="Assets/app.ico"
        Height="560"
        Width="980">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="24" FontWeight="Bold" Text="WinAudioBridge" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="#666"
                       Text="应用已在系统托盘运行。通过托盘菜单打开设置或退出程序。" />
            <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
            <Button Width="100"
                Margin="0,0,8,0"
                Click="PrepareLink_Click"
                IsEnabled="{Binding CanPrepare}">准备链路</Button>
            <Button Width="100"
                Margin="0,0,8,0"
                Click="StartStreaming_Click"
                IsEnabled="{Binding CanStart}">开始推流</Button>
            <Button Width="100"
                Click="StopStreaming_Click"
                IsEnabled="{Binding CanStop}">停止推流</Button>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="16"
                Background="#F7F7F7"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="当前配置" />
                <UniformGrid Margin="0,12,0,0" Columns="2" Rows="6">
                    <TextBlock FontWeight="SemiBold" Text="编码" />
                    <TextBlock Text="{Binding Encoding}" />
                    <TextBlock FontWeight="SemiBold" Text="采样率" />
                    <TextBlock Text="{Binding SampleRateText}" />
                    <TextBlock FontWeight="SemiBold" Text="声道数" />
                    <TextBlock Text="{Binding ChannelsText}" />
                    <TextBlock FontWeight="SemiBold" Text="Buffer" />
                    <TextBlock Text="{Binding BufferText}" />
                    <TextBlock FontWeight="SemiBold" Text="Android 包名" />
                    <TextBlock Text="{Binding AndroidPackageName}" />
                    <TextBlock FontWeight="SemiBold" Text="优先设备" />
                    <TextBlock Text="{Binding PreferredDeviceText}" />
                </UniformGrid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="16"
                    Background="#FAFAFA"
                    BorderBrush="#E5E5E5"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="推流骨架状态" />
                    <UniformGrid Margin="0,12,0,0" Columns="2" Rows="9">
                        <TextBlock FontWeight="SemiBold" Text="协调器状态" />
                        <TextBlock Text="{Binding CoordinatorStateText}" />
                        <TextBlock FontWeight="SemiBold" Text="状态说明" />
                        <TextBlock Text="{Binding CoordinatorStatusMessage}" TextWrapping="Wrap" />
                        <TextBlock FontWeight="SemiBold" Text="目标设备" />
                        <TextBlock Text="{Binding TargetDeviceText}" TextWrapping="Wrap" />
                        <TextBlock FontWeight="SemiBold" Text="传输状态" />
                        <TextBlock Text="{Binding TransportStatusText}" />
                        <TextBlock FontWeight="SemiBold" Text="采集状态" />
                        <TextBlock Text="{Binding CaptureStatusText}" />
                        <TextBlock FontWeight="SemiBold" Text="音量监控" />
                        <TextBlock Text="{Binding WindowsVolumeMonitorText}" />
                        <TextBlock FontWeight="SemiBold" Text="主音量" />
                        <TextBlock Text="{Binding WindowsMasterVolumeText}" TextWrapping="Wrap" />
                        <TextBlock FontWeight="SemiBold" Text="主静音" />
                        <TextBlock Text="{Binding WindowsMasterMuteText}" />
                        <TextBlock FontWeight="SemiBold" Text="应用会话" />
                        <TextBlock Text="{Binding WindowsVolumeSessionCountText}" />
                        <TextBlock FontWeight="SemiBold" Text="最近同步" />
                        <TextBlock Text="{Binding WindowsVolumeLastSyncText}" />
                    </UniformGrid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="16"
                    Background="#FAFAFA"
                    BorderBrush="#E5E5E5"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="诊断日志" />
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding RecentLogs}"
                             BorderThickness="0"
                             Background="Transparent"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                           FontSize="12"
                                           Text="{Binding DisplayText}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
